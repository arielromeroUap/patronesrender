---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UserCard from '../../components/UserCard.jsx';


export async function getStaticPaths() {
  try {
    const response = await fetch('http://localhost:3000/api/users');
    
    // Verificamos si la respuesta es realmente JSON
    const contentType = response.headers.get("content-type");
    if (!contentType || !contentType.includes("application/json")) {
      const text = await response.text();
      console.error("¡Error! La API no devolvió JSON. Devolvió esto:", text.slice(0, 100));
      return []; // Retornamos vacío para que no rompa el build pero veamos el error
    }

    const users = await response.json();
    return users.map((user) => ({
      params: { id: user.id.toString() },
      props: { user },
    }));
  } catch (e) {
    console.error("Error de conexión con la API:", e);
    return [];
  }
}
// ESTA ES LA LÍNEA QUE FALTA:
const { user } = Astro.props;
---

<BaseLayout title={user.name}>
  <h1>Perfil Estático de {user.name}</h1>
  <p>Email: {user.email}</p>
  
  {/* ¡La ISLA de React sigue funcionando igual! */}
  <UserCard client:load user={user} />
</BaseLayout>